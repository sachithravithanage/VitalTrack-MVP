# Production MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_DB_NAME=vitaltrack

# App Configuration
NODE_ENV=production
PORT=5000
API_VERSION=v1

# JWT Configuration
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# PDF Generation (optional local/mock storage key)
PDF_STORAGE_BUCKET=

# Email Service (Optional - for notifications)
SENDGRID_API_KEY=
NOTIFICATION_EMAIL_FROM=noreply@vitaltrack.app
