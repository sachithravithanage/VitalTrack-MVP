rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Local development rules for emulator usage.
    // Tighten these for production deployment.

    // Allow OTP flow during signup/login
    match /otps/{otpHash} {
      allow read, write: if true;
    }

    // Require authentication for all other documents
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
