{
  "projects": {
    "default": "vitaltrack-vcode"
  },
  "firestore": {
    "rules": "src/firestore/firestore.rules",
    "indexes": "src/firestore/firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  },
  "emulators": {
    "auth": {
      "host": "localhost",
      "port": 9099
    },
    "firestore": {
      "host": "localhost",
      "port": 8080
    },
    "storage": {
      "host": "localhost",
      "port": 9199
    },
    "hosting": {
      "host": "localhost",
      "port": 5001
    },
    "ui": {
      "enabled": true,
      "host": "localhost",
      "port": 4000
    },
    "pubsub": {
      "port": 8085
    }
  }
}
